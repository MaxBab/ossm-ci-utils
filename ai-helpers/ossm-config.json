{
  "ossm_confidence_config": {
    "description": "Configuration for OSSM Release Confidence Score calculation with FULL/CORE/BASIC test scope support",
    "report_portal": {
      "mcp_server_name": "reportportal",
      "default_project": "ossm",
      "test_stages": [
        "upstream",
        "midstream",
        "downstream"
      ],
      "platforms": [
        "OSP",
        "AWS",
        "ROSA",
        "ARO",
        "IBM Z & P"
      ],
      "environments": [
        "Normal",
        "FIPS",
        "Disconnected",
        "IPv6",
        "DualStack",
        "ARM"
      ]
    },
    "test_scope_classification": {
      "FULL": {
        "description": "Complete test coverage for new minor OSSM version releases",
        "triggers": [
          "New minor OSSM version (3.1, 3.2, 3.3, etc.)"
        ]
      },
      "CORE": {
        "description": "Reduced test coverage for code changes and patch updates",
        "triggers": [
          "Code changes in istio/proxy/ztunnel midstream repos",
          "Istio patch version updates (e.g., 1.26.5 → 1.26.6)",
          "CVE fixes in our codebase",
          "Code changes in sail operator repo"
        ]
      },
      "BASIC": {
        "description": "Minimal test coverage for automated updates",
        "triggers": [
          "Auto base image updates in Konflux"
        ]
      }
    },
    "test_suites": {
      "O": {
        "name": "Sail e2e tests",
        "description": "End-to-end testing of Sail operator functionality"
      },
      "II": {
        "name": "Istio integration",
        "description": "Istio integration tests",
        "notes": "Ambient tests included from OSSM 3.2+; ambient tests skipped on FIPS clusters"
      },
      "KI": {
        "name": "Kiali integration",
        "description": "Kiali integration testing"
      },
      "KU": {
        "name": "Kiali cypress UI",
        "description": "Kiali UI testing with Cypress",
        "notes": "Ambient tests included from OSSM 3.2+; ambient tests skipped on FIPS clusters"
      },
      "KO": {
        "name": "Kiali OSSMC cypress",
        "description": "Kiali OSSMC UI testing with Cypress",
        "notes": "Ambient tests included from OSSM 3.2+; ambient tests skipped on FIPS clusters"
      },
      "U": {
        "name": "Upgrade tests",
        "description": "inChannel for each [3.x.z → 3.x.z+1], crossChannel through all [3.x.y → 3.x+1.z]"
      },
      "M": {
        "name": "Migration tests",
        "description": "Migration testing",
        "notes": "OSSM 3.0.z only"
      },
      "GIE": {
        "name": "GIE conformance",
        "description": "Gateway API conformance testing",
        "notes": "OSSM 3.2+"
      }
    },
    "ocp_version_mapping": {
      "3.0": {
        "min_ocp": "4.14",
        "max_ocp": "4.19"
      },
      "3.1": {
        "min_ocp": "4.16",
        "max_ocp": "4.20"
      },
      "3.2": {
        "min_ocp": "4.18",
        "max_ocp": "4.20+"
      }
    },
    "confidence_weights": {
      "test_pass_rate": 0.25,
      "test_coverage_completeness": 0.25,
      "flaky_test_ratio": 0.20,
      "critical_defects": 0.20,
      "version_stability": 0.10
    },
    "test_scope_matrix": {
      "FULL": {
        "required_test_suites": ["O", "II", "KI", "KU", "KO", "U", "GIE"],
        "required_platforms": ["OSP", "AWS", "ROSA", "ARO", "IBM Z & P"],
        "required_environments": ["Normal", "FIPS", "Disconnected", "IPv6", "DualStack", "ARM"],
        "ocp_coverage": "all_compatible_versions",
        "test_combinations": [
          {"platform": "OSP", "environment": "Disconnected", "tests": ["O", "KI"]},
          {"platform": "AWS", "environment": "FIPS", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "ARM", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "Normal", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "ROSA", "environment": "FIPS", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "IPv6", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "DualStack", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "ARO", "environment": "Normal", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "Normal", "ocp": "preGA", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "IBM Z & P", "environment": "Normal", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "IBM Z & P", "environment": "FIPS", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "Normal", "ocp": "preGA", "tests": ["GIE"]},
          {"platform": "AWS", "environment": "Normal", "upgrade": true, "tests": ["U"]}
        ]
      },
      "CORE": {
        "required_test_suites": ["O", "II", "KI", "KU", "KO", "U"],
        "required_platforms": ["AWS", "ROSA", "ARO", "IBM Z & P"],
        "required_environments": ["Normal", "FIPS", "ARM"],
        "ocp_coverage": "primary_versions",
        "test_combinations": [
          {"platform": "OSP", "environment": "Disconnected", "tests": ["O", "KI"]},
          {"platform": "AWS", "environment": "FIPS", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "ARM", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "Normal", "tests": ["O", "II", "KU"]},
          {"platform": "ROSA", "environment": "FIPS", "tests": ["O", "KU"]},
          {"platform": "AWS", "environment": "IPv6", "tests": ["O", "KU"]},
          {"platform": "AWS", "environment": "DualStack", "tests": ["O", "KU"]},
          {"platform": "ARO", "environment": "Normal", "tests": ["O", "KU"]},
          {"platform": "IBM Z & P", "environment": "Normal", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "IBM Z & P", "environment": "FIPS", "tests": ["O", "II", "KU"]},
          {"platform": "AWS", "environment": "Normal", "ocp": "preGA", "tests": ["GIE"]},
          {"platform": "AWS", "environment": "Normal", "upgrade": true, "tests": ["U"]}
        ]
      },
      "BASIC": {
        "required_test_suites": ["O", "II", "KI", "KU"],
        "required_platforms": ["AWS", "ROSA", "IBM Z & P"],
        "required_environments": ["Normal", "FIPS"],
        "ocp_coverage": "latest_primary",
        "test_combinations": [
          {"platform": "AWS", "environment": "Disconnected", "tests": ["O", "KI"]},
          {"platform": "AWS", "environment": "FIPS", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "ARM", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "AWS", "environment": "Normal", "tests": ["O", "II", "KU"]},
          {"platform": "IBM Z & P", "environment": "Normal", "tests": ["O", "II", "KI", "KU", "KO"]},
          {"platform": "IBM Z & P", "environment": "FIPS", "tests": ["O", "KU"]},
          {"platform": "AWS", "environment": "Normal", "ocp": "preGA", "tests": ["GIE"]},
          {"platform": "AWS", "environment": "Normal", "tests": ["U"]},
          {"platform": "AWS", "environment": "Normal", "migration": "2.6", "tests": ["M"]}
        ]
      }
    },
    "score_thresholds": {
      "release_approved": 9.0,
      "needs_attention": 5.0,
      "critical_issues": 3.0,
      "scope_not_met": 2.0
    },
    "version_tracking": {
      "components": [
        "ossm_operator",
        "istio",
        "sail_operator"
      ],
      "stability_indicators": {
        "stable": ["patch", "minor"],
        "risky": ["major", "rc", "beta", "alpha", "snapshot"]
      }
    },
    "critical_test_tags": [
      "critical",
      "p0",
      "blocker",
      "security",
      "performance_regression"
    ],
    "flaky_test_indicators": [
      "flaky",
      "intermittent",
      "unstable"
    ]
  }
}